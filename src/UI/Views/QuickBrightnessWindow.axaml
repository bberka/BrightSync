<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:BrightSync.UI.ViewModels"
        x:Class="BrightSync.UI.Views.QuickBrightnessWindow"
        x:DataType="vm:QuickBrightnessViewModel"
        x:CompileBindings="True"
        Width="300"
        SizeToContent="Height"
        WindowStartupLocation="Manual"
        CanResize="False"
        ShowInTaskbar="False"
        WindowDecorations="None"
        Topmost="True"
        Background="Transparent">

    <Border CornerRadius="8"
            Background="#1e1e1e"
            BorderBrush="#353535"
            BorderThickness="1"
            Padding="16,14">
        <StackPanel Spacing="10">
            <!-- Automatic Brightness -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="Automatic Brightness"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="White" />
                    <TextBlock Text="{Binding AutoBrightnessStatusText}"
                               FontSize="11"
                               Foreground="#a0a0a0"
                               TextWrapping="Wrap" />
                </StackPanel>
                <ToggleSwitch Grid.Column="1"
                              IsChecked="{Binding AutoBrightnessEnabled}"
                              OnContent="" OffContent=""
                              VerticalAlignment="Center"
                              Margin="12,0,0,0" />
            </Grid>

            <!-- Eye Protection -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="Eye Protection"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="White" />
                    <TextBlock Text="{Binding EyeProtectionStatusText}"
                               FontSize="11"
                               Foreground="#a0a0a0"
                               TextWrapping="Wrap" />
                </StackPanel>
                <ToggleSwitch Grid.Column="1"
                              IsChecked="{Binding EyeProtectionEnabled}"
                              OnContent="" OffContent=""
                              VerticalAlignment="Center"
                              Margin="12,0,0,0" />
            </Grid>

            <!-- Brightness Boost -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="Brightness Boost"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="White" />
                    <TextBlock Text="{Binding BrightnessBoostStatusText}"
                               FontSize="11"
                               Foreground="#a0a0a0"
                               TextWrapping="Wrap" />
                </StackPanel>
                <ToggleSwitch Grid.Column="1"
                              IsChecked="{Binding BrightnessBoostEnabled}"
                              OnContent="" OffContent=""
                              VerticalAlignment="Center"
                              Margin="12,0,0,0" />
            </Grid>

            <!-- Internal brightness slider -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="42" />
                </Grid.ColumnDefinitions>
                <Slider Grid.Column="0"
                        Minimum="0" Maximum="100"
                        Value="{Binding InternalBrightness}"
                        TickFrequency="5"
                        IsSnapToTickEnabled="True"
                        VerticalAlignment="Center"
                        IsEnabled="{Binding IsManualBrightnessEnabled}" />
                <TextBlock Grid.Column="1"
                           Text="{Binding InternalBrightnessText}"
                           FontSize="13" FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           TextAlignment="Right"
                           Foreground="White" />
            </Grid>

            <TextBlock Text="Curve editing is available in Settings."
                       FontSize="11"
                       Foreground="#a0a0a0"
                       IsVisible="{Binding AutoBrightnessEnabled}" />

            <TextBlock Text="{Binding IdleReductionStatusText}"
                       FontSize="11"
                       Foreground="#a0a0a0"
                       IsVisible="{Binding IsIdleReductionActive}" />

            <!-- Monitor targets -->
            <ItemsControl ItemsSource="{Binding MonitorTargets}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:MonitorTargetInfo">
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Name}"
                                       FontSize="12"
                                       Foreground="#a0a0a0"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding TargetText}"
                                       FontSize="12"
                                       Margin="8,0,0,0"
                                       Foreground="#a0a0a0" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Settings link -->
            <Border BorderThickness="0,1,0,0"
                    BorderBrush="#353535"
                    Padding="0,8,0,0">
                <Button Content="Settings"
                        Command="{Binding OpenSettingsCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        FontSize="12" />
            </Border>
        </StackPanel>
    </Border>
</Window>
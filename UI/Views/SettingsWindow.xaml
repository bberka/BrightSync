<Window x:Class="BrightSync.UI.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="BrightSync"
    Width="420"
    MaxWidth="420"
    MinHeight="385"
    MaxHeight="770"
    SizeToContent="Height"
    WindowStartupLocation="Manual"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowStyle="None"
    AllowsTransparency="True"
    Topmost="True"
    Background="Transparent">

    <Border CornerRadius="8"
            Background="{DynamicResource ApplicationBackgroundBrush}"
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
            BorderThickness="1">

        <Border.Resources>
            <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

            <!-- Chevron toggle with custom template to prevent WPF-UI blue hover -->
            <Style x:Key="ChevronToggle" TargetType="ToggleButton">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="Bd" Background="Transparent" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background"
                                            Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background"
                                            Value="{DynamicResource SubtleFillColorTertiaryBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                <Setter Property="FontSize" Value="10"/>
                <Setter Property="Width" Value="24"/>
                <Setter Property="Height" Value="24"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Content" Value="&#xE76C;"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
                <Style.Triggers>
                    <Trigger Property="IsChecked" Value="True">
                        <Setter Property="Content" Value="&#xE70D;"/>
                    </Trigger>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Title bar button (minimize to tray) -->
            <Style x:Key="TitleBarButton" TargetType="Button">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="Transparent"
                                    CornerRadius="4" Width="32" Height="28">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background"
                                            Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background"
                                            Value="{DynamicResource SubtleFillColorTertiaryBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                <Setter Property="FontSize" Value="10"/>
                <Setter Property="Cursor" Value="Hand"/>
            </Style>

            <!-- Title bar close button (red hover) -->
            <Style x:Key="TitleBarCloseButton" TargetType="Button">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="Transparent"
                                    CornerRadius="4" Width="32" Height="28">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#C42B1C"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#B3271A"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                <Setter Property="FontSize" Value="10"/>
                <Setter Property="Cursor" Value="Hand"/>
            </Style>

            <!-- Section header -->
            <Style x:Key="SectionHeader" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
                <Setter Property="Margin" Value="0,12,0,6"/>
            </Style>

            <!-- Slider row label -->
            <Style x:Key="SliderLabel" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Width" Value="44"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
            </Style>

            <!-- Slider row value -->
            <Style x:Key="SliderValue" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Width" Value="42"/>
                <Setter Property="TextAlignment" Value="Right"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            </Style>
        </Border.Resources>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Custom title bar -->
            <Border Grid.Row="0" Background="Transparent" Padding="12,6,6,6"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                               FontSize="12" FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    <Button Grid.Column="1"
                            Style="{StaticResource TitleBarButton}"
                            Content="&#xE921;"
                            ToolTip="Send to Tray"
                            Click="MinimizeToTray_Click"
                            Margin="0,0,2,0"/>
                    <Button Grid.Column="2"
                            Style="{StaticResource TitleBarCloseButton}"
                            Content="&#xE8BB;"
                            ToolTip="Exit"
                            Click="Exit_Click"/>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8,8,8,8">
                <StackPanel Width="390">
                    <!-- Internal brightness -->
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Brightness" Margin="0,4,0,6"/>
                    <ui:Card Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource SliderLabel}" Text="Level"/>
                            <Slider Grid.Column="1"
                                    Minimum="0" Maximum="100"
                                    Value="{Binding InternalBrightness, UpdateSourceTrigger=PropertyChanged}"
                                    TickFrequency="5" IsSnapToTickEnabled="True"
                                    IsMoveToPointEnabled="True"
                                    IsEnabled="{Binding IsManualBrightnessEnabled}"
                                    VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding InternalBrightnessText}"
                                       FontSize="13" FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       MinWidth="44" TextAlignment="Right"/>
                        </Grid>
                    </ui:Card>

                    <!-- Options -->
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Options"/>
                    <ui:Card Padding="12,10">
                        <StackPanel>
                            <!-- Start with Windows -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Start with Windows"
                                           FontSize="13" VerticalAlignment="Center"/>
                                <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding StartWithWindows}"/>
                            </Grid>

                            <Border Height="1"
                                    Background="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    Margin="0,8"/>

                            <!-- Enforcement toggle -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Enforce brightness" FontSize="13"/>
                                    <TextBlock Text="Re-applies brightness periodically"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                                <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding EnforcementEnabled}"/>
                            </Grid>

                            <!-- Enforcement interval (visible when enabled) -->
                            <Grid Margin="0,8,0,0"
                                  Visibility="{Binding EnforcementEnabled, Converter={StaticResource BoolToVisibility}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="140"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Interval"
                                           FontSize="13" VerticalAlignment="Center"
                                           Margin="16,0,0,0"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal"
                                            HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Slider Width="80"
                                            Minimum="5" Maximum="120"
                                            Value="{Binding EnforcementIntervalSeconds}"
                                            TickFrequency="5" IsSnapToTickEnabled="True"
                                            IsMoveToPointEnabled="True"
                                            VerticalAlignment="Center"/>
                                    <TextBlock FontSize="13" VerticalAlignment="Center" Margin="8,0,0,0"
                                               MinWidth="32"
                                               Text="{Binding EnforcementIntervalSeconds, StringFormat='{}{0}s'}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </ui:Card>

                    <!-- Monitors -->
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Monitor Configs"/>

                    <!-- Empty state -->
                    <TextBlock Text="{Binding EmptyStateText}"
                               FontSize="13"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasMonitors}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Monitor list -->
                    <ItemsControl ItemsSource="{Binding Monitors}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ui:Card Margin="0,0,0,8" Padding="12,10">
                                    <StackPanel>
                                        <!-- Header row -->
                                        <Border Background="Transparent">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Cursor" Value="Arrow"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CanExpand}" Value="True">
                                                            <Setter Property="Cursor" Value="Hand"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid MouseLeftButtonDown="MonitorHeader_MouseLeftButtonDown">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <ToggleButton Grid.Column="0"
                                                          IsChecked="{Binding IsExpanded}"
                                                          IsHitTestVisible="False"
                                                          VerticalAlignment="Center">
                                                <ToggleButton.Style>
                                                    <Style TargetType="ToggleButton" BasedOn="{StaticResource ChevronToggle}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CanExpand}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ToggleButton.Style>
                                            </ToggleButton>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                <TextBlock Text="{Binding InfoLine}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <ui:ToggleSwitch Grid.Column="2"
                                                             IsChecked="{Binding Enabled}"
                                                             IsEnabled="{Binding CanToggleEnabled}"
                                                             VerticalAlignment="Center"
                                                             Margin="8,0,0,0"/>
                                            </Grid>
                                        </Border>

                                        <!-- Expandable content -->
                                        <StackPanel Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibility}}"
                                                    IsEnabled="{Binding Enabled}"
                                                    Margin="32,10,0,0">

                                            <!-- DDC/CI controls -->
                                            <StackPanel IsEnabled="{Binding SupportsDdcCi}">
                                                <!-- Min brightness -->
                                                <Grid Margin="0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="44"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="42"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Style="{StaticResource SliderLabel}" Text="Min"/>
                                                    <Slider Grid.Column="1"
                                                            Minimum="0" Maximum="100"
                                                            Value="{Binding MinBrightness}"
                                                            TickFrequency="5" IsSnapToTickEnabled="True"
                                                            IsMoveToPointEnabled="True"
                                                            VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Style="{StaticResource SliderValue}"
                                                               Text="{Binding MinBrightness, StringFormat='{}{0}%'}"/>
                                                </Grid>

                                                <!-- Max brightness -->
                                                <Grid Margin="0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="44"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="42"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Style="{StaticResource SliderLabel}" Text="Max"/>
                                                    <Slider Grid.Column="1"
                                                            Minimum="0" Maximum="100"
                                                            Value="{Binding MaxBrightness}"
                                                            TickFrequency="5" IsSnapToTickEnabled="True"
                                                            IsMoveToPointEnabled="True"
                                                            VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Style="{StaticResource SliderValue}"
                                                               Text="{Binding MaxBrightness, StringFormat='{}{0}%'}"/>
                                                </Grid>

                                                <!-- Scale multiplier -->
                                                <Grid Margin="0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="44"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="42"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Style="{StaticResource SliderLabel}" Text="Scale"/>
                                                    <Slider Grid.Column="1"
                                                            Minimum="0.1" Maximum="3.0"
                                                            Value="{Binding Multiplier}"
                                                            SmallChange="0.05" LargeChange="0.25"
                                                            IsMoveToPointEnabled="True"
                                                            VerticalAlignment="Center"
                                                            ToolTip="1.0 = match internal · 1.5 = 50% brighter"/>
                                                    <TextBlock Grid.Column="2" Style="{StaticResource SliderValue}"
                                                               Text="{Binding MultiplierDisplay}"/>
                                                </Grid>

                                                <!-- Live target -->
                                                <TextBlock Text="{Binding TargetText}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                                           Margin="0,6,0,0"/>
                                            </StackPanel>

                                            <!-- No DDC/CI notice -->
                                            <TextBlock FontSize="11"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       Margin="0,4,0,0"
                                                       Text="{Binding CapabilityNoticeText}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasCapabilityNotice}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <!-- Reset button -->
                                            <Grid Margin="0,8,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <ui:Button Grid.Column="1"
                                                           Content="Reset"
                                                           Command="{Binding ResetCommand}"
                                                           Appearance="Secondary"/>
                                            </Grid>
                                        </StackPanel>
                                    </StackPanel>
                                </ui:Card>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="Automatic Brightness"/>
                    <ui:Card Padding="12,10">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Follow a smooth 24-hour brightness curve"
                                               FontSize="13"/>
                                    <TextBlock Text="{Binding AutoBrightnessStatusText}"
                                               FontSize="11"
                                               Margin="0,2,0,0"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <ui:ToggleSwitch Grid.Column="1"
                                                 IsChecked="{Binding AutoBrightnessEnabled}"
                                                 VerticalAlignment="Center"/>
                            </Grid>

                            <Grid Margin="0,10,0,0"
                                  Visibility="{Binding AutoBrightnessEnabled, Converter={StaticResource BoolToVisibility}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="180"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="Drag the curve points to change brightness through the day."
                                               FontSize="11"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding AutoBrightnessPreviewText}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Margin="8,0,0,0"
                                               Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <ui:Button Grid.Column="2"
                                               Content="Reset Curve"
                                               Command="{Binding ResetCurveCommand}"
                                               Appearance="Secondary"
                                               Margin="8,0,0,0"/>
                                </Grid>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0"
                                          Margin="0,0,8,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0"
                                                   Text="100"
                                                   FontSize="10"
                                                   VerticalAlignment="Top"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Grid.Row="1"
                                                   Text="75"
                                                   FontSize="10"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Grid.Row="2"
                                                   Text="50"
                                                   FontSize="10"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Grid.Row="3"
                                                   Text="25"
                                                   FontSize="10"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Grid.Row="4"
                                                   Text="0"
                                                   FontSize="10"
                                                   VerticalAlignment="Bottom"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </Grid>

                                    <Border Grid.Column="1"
                                            CornerRadius="6"
                                            Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                        <Canvas x:Name="AutoBrightnessCurveCanvas"
                                                Background="Transparent"
                                                SizeChanged="AutoBrightnessCurveCanvas_SizeChanged"
                                                MouseLeftButtonUp="AutoBrightnessCurveCanvas_MouseLeftButtonUp"
                                                MouseMove="AutoBrightnessCurveCanvas_MouseMove"/>
                                    </Border>
                                </Grid>

                                <UniformGrid Grid.Row="2"
                                             Margin="38,8,0,0"
                                             Columns="9">
                                    <TextBlock Text="0" FontSize="10" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="3" FontSize="10" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="6" FontSize="10" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="9" FontSize="10" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="12" FontSize="10" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="15" FontSize="10" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="18" FontSize="10" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="21" FontSize="10" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="24" FontSize="10" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </UniformGrid>
                            </Grid>
                        </StackPanel>
                    </ui:Card>
                </StackPanel>
            </ScrollViewer>

            <!-- Bottom action bar -->
            <Border Grid.Row="2"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    Padding="16,10">
                <StackPanel>
                    <TextBlock Text="{Binding StatusText}"
                               FontSize="11"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"
                               MinHeight="16"
                               Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ui:Button Grid.Column="1"
                                   Content="Reset All"
                                   Command="{Binding ResetAllCommand}"
                                   Appearance="Secondary"
                                   Margin="0,0,6,0"/>
                        <ui:Button Grid.Column="2"
                                   Content="Check Updates"
                                   Command="{Binding CheckForUpdatesCommand}"
                                   Appearance="Secondary"
                                   Margin="0,0,6,0"/>
                        <ui:Button Grid.Column="3"
                                   Content="Refresh"
                                   Command="{Binding RefreshCommand}"
                                   Appearance="Secondary"
                                   Margin="0,0,6,0"/>
                        <ui:Button Grid.Column="4"
                                   Content="Save"
                                   Command="{Binding SaveCommand}"
                                   Appearance="Primary"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Exit confirmation overlay -->
            <Border x:Name="ExitOverlay"
                    Grid.Row="0" Grid.RowSpan="3"
                    Background="#80000000"
                    Visibility="Collapsed">
                <Border Background="{DynamicResource ApplicationBackgroundBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="24,20"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MinWidth="300"
                        MaxWidth="340">
                    <StackPanel>
                        <TextBlock Text="Exit BrightSync"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <TextBlock Text="Are you sure you want to exit?&#x0a;BrightSync will stop syncing monitor brightness."
                                   FontSize="13"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,16"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:Button Grid.Column="1"
                                       Content="Cancel"
                                       Appearance="Secondary"
                                       Click="ExitOverlay_Cancel_Click"
                                       Margin="0,0,6,0"/>
                            <ui:Button Grid.Column="2"
                                       Content="Exit"
                                       Appearance="Danger"
                                       Click="ExitOverlay_Confirm_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </Border>
</Window>

<ui:FluentWindow
    x:Class="BrightSync.UI.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:local="clr-namespace:BrightSync.UI"
    Title="BrightSync"
    Width="360"
    MaxWidth="360"
    MinHeight="200"
    MaxHeight="680"
    SizeToContent="Height"
    WindowStartupLocation="Manual"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>
        <local:BoolToOpacityConverter x:Key="BoolToOpacity"/>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,10,0,4"/>

        </Style>

        <Style x:Key="SliderLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
        </Style>

        <Style x:Key="SliderValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Width" Value="38"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- TitleBar -->
            <RowDefinition Height="*"/>     <!-- Content -->
        </Grid.RowDefinitions>

        <!-- Title bar — close only, no min/max -->
        <ui:TitleBar
            Grid.Row="0"
            Title="BrightSync"
            ShowMinimize="False"
            ShowMaximize="False"
            ForceShutdown="False"/>

        <!-- Scrollable content -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="14,4,14,14">
            <StackPanel>

                <!-- ── Internal display ── -->
                <TextBlock Style="{StaticResource SectionLabel}" Text="Internal Display" Margin="0,0,0,4"/>
                <ui:Card Padding="12,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ProgressBar Grid.Column="0"
                                     Height="4"
                                     Minimum="0" Maximum="100"
                                     Value="{Binding InternalBrightness, Mode=OneWay}"
                                     VerticalAlignment="Center"
                                     Margin="0,0,12,0"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding InternalBrightnessText}"
                                   FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   MinWidth="40" TextAlignment="Right"/>
                    </Grid>
                </ui:Card>

                <!-- ── External monitors ── -->
                <TextBlock Style="{StaticResource SectionLabel}" Text="External Monitors"/>

                <!-- Empty state -->
                <TextBlock Text="{Binding StatusText}"
                           FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"
                           Visibility="{Binding HasMonitors,
                               Converter={StaticResource BoolToOpacity},
                               ConverterParameter=invert}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasMonitors}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <ItemsControl ItemsSource="{Binding Monitors}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ui:Card Margin="0,0,0,6" Padding="12,10">
                                <StackPanel>

                                    <!-- Monitor header -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                            <!-- Resolution + DDC status on one line -->
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <TextBlock Text="{Binding ResolutionText}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                <TextBlock FontSize="11" Margin="6,0,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SupportsDdcCi}" Value="True">
                                                                    <Setter Property="Text" Value="· DDC/CI ✓"/>
                                                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding SupportsDdcCi}" Value="False">
                                                                    <Setter Property="Text" Value="· No DDC/CI"/>
                                                                    <Setter Property="Foreground" Value="#FF7043"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Enabled toggle -->
                                        <ui:ToggleSwitch Grid.Column="1"
                                                         IsChecked="{Binding Enabled}"
                                                         VerticalAlignment="Center"
                                                         Margin="8,0,0,0"/>
                                    </Grid>

                                    <!-- Sliders — faded out when no DDC/CI support -->
                                    <StackPanel Opacity="{Binding SupportsDdcCi, Converter={StaticResource BoolToOpacity}}"
                                                IsEnabled="{Binding SupportsDdcCi}">

                                        <!-- Min brightness -->
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="38"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Style="{StaticResource SliderLabel}" Text="Min"/>
                                            <Slider Grid.Column="1"
                                                    Minimum="0" Maximum="100"
                                                    Value="{Binding MinBrightness}"
                                                    TickFrequency="5" IsSnapToTickEnabled="True"
                                                    VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Style="{StaticResource SliderValue}"
                                                       Text="{Binding MinBrightness, StringFormat='{}{0}%'}"/>
                                        </Grid>

                                        <!-- Max brightness -->
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="38"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Style="{StaticResource SliderLabel}" Text="Max"/>
                                            <Slider Grid.Column="1"
                                                    Minimum="0" Maximum="100"
                                                    Value="{Binding MaxBrightness}"
                                                    TickFrequency="5" IsSnapToTickEnabled="True"
                                                    VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Style="{StaticResource SliderValue}"
                                                       Text="{Binding MaxBrightness, StringFormat='{}{0}%'}"/>
                                        </Grid>

                                        <!-- Scale multiplier -->
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="38"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Style="{StaticResource SliderLabel}" Text="Scale"/>
                                            <Slider Grid.Column="1"
                                                    Minimum="0.1" Maximum="3.0"
                                                    Value="{Binding Multiplier}"
                                                    SmallChange="0.05" LargeChange="0.25"
                                                    VerticalAlignment="Center"
                                                    ToolTip="1.0 = match internal · 1.5 = 50% brighter · 0.8 = dimmer"/>
                                            <TextBlock Grid.Column="2" Style="{StaticResource SliderValue}"
                                                       Text="{Binding MultiplierDisplay}"/>
                                        </Grid>

                                        <!-- Live target -->
                                        <TextBlock Text="{Binding TargetText}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                                   Margin="0,5,0,0"/>
                                    </StackPanel>

                                </StackPanel>
                            </ui:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- ── Options ── -->
                <TextBlock Style="{StaticResource SectionLabel}" Text="Options"/>
                <ui:Card Padding="12,10">
                    <StackPanel>
                        <!-- Start with Windows -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Start with Windows" FontSize="13"/>
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding StartWithWindows}"/>
                        </Grid>

                        <!-- Enforcement interval -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="140"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Enforce every" FontSize="13"/>
                                <TextBlock Text="Re-applies brightness after power cycles"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Slider Width="80"
                                        Minimum="5" Maximum="120"
                                        Value="{Binding EnforcementIntervalSeconds}"
                                        TickFrequency="5" IsSnapToTickEnabled="True"
                                        VerticalAlignment="Center"/>
                                <TextBlock FontSize="12" VerticalAlignment="Center" Margin="6,0,0,0"
                                           MinWidth="32"
                                           Text="{Binding EnforcementIntervalSeconds, StringFormat='{}{0}s'}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- ── Action buttons ── -->
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding StatusText}"
                               FontSize="11"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <ui:Button Grid.Column="1"
                               Content="Refresh"
                               Command="{Binding RefreshCommand}"
                               Margin="0,0,6,0"/>
                    <ui:Button Grid.Column="2"
                               Content="Save"
                               Command="{Binding SaveCommand}"
                               Appearance="Primary"/>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>

<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="BrightSync.App"
             RequestedThemeVariant="Dark">
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="avares://BrightSync/Resources/app.ico" ToolTipText="BrightSync" />
        </TrayIcons>
    </TrayIcon.Icons>
</Application>
